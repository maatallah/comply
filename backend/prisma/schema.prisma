// Prisma Schema - TuniCompliance
// Auto-generated from DATA_MODEL_V2.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== COMPANY & USERS ====================

model Company {
  id             String   @id @default(uuid())
  legalName      String   @map("legal_name")
  tradeName      String?  @map("trade_name")
  taxId          String   @unique @map("tax_id") // Tunisia: XXXXXXX/X/A/M/XXX
  cnssId         String?  @map("cnss_id")
  activitySector String   @map("activity_sector") // TEXTILE, CONSTRUCTION, etc.
  companySize    String   @map("company_size") // SMALL, MEDIUM, LARGE
  employeeCount  Int?     @map("employee_count")
  address        String?
  city           String?
  region         String?
  country        String   @default("TN")
  phone          String?
  email          String?
  website        String?
  isActive       Boolean  @default(true) @map("is_active")
  regime         String   @default("ONSHORE") // ONSHORE or OFFSHORE
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  users       User[]
  obligations Obligation[]
  deadlines   Deadline[]
  checks      Check[]
  audits      Audit[]
  alerts      Alert[]

  @@map("companies")
}

model User {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  email             String   @unique
  passwordHash      String   @map("password_hash")
  firstName         String   @map("first_name")
  lastName          String   @map("last_name")
  role              String   // COMPANY_ADMIN, COMPLIANCE_OFFICER, EMPLOYEE
  phone             String?
  preferredLanguage String   @default("fr") @map("preferred_language") // fr, ar
  isActive          Boolean  @default(true) @map("is_active")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  checks  Check[]
  alerts  Alert[]
  
  // Audit Relations
  ledAudits      Audit[] @relation("LeadAuditor")
  teamAudits     Audit[] @relation("AuditTeam")
  assignedActions CorrectiveAction[]

  @@map("users")
}

// ==================== REGULATIONS & OBLIGATIONS ====================

model Regulation {
  id            String   @id @default(uuid())
  code          String   @unique // e.g., "Décret 75-503"
  titleFr       String   @map("title_fr")
  titleAr       String?  @map("title_ar")
  authority     String   // PROTECTION_CIVILE, CNSS, ANPE, etc.
  category      String   // HSE, FISCAL, SOCIAL, ENVIRONMENTAL, BRAND_AUDIT, QUALITY
  descriptionFr String?  @map("description_fr") @db.Text
  descriptionAr String?  @map("description_ar") @db.Text
  effectiveDate DateTime? @map("effective_date")
  sourceUrl     String?  @map("source_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  obligations Obligation[]
  articles    Article[]

  @@map("regulations")
}

model Obligation {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  regulationId   String   @map("regulation_id")
  titleFr        String   @map("title_fr")
  titleAr        String?  @map("title_ar")
  descriptionFr  String?  @map("description_fr") @db.Text
  descriptionAr  String?  @map("description_ar") @db.Text
  category       String   // HSE, FISCAL, SOCIAL, etc.
  frequency      String   // MONTHLY, QUARTERLY, ANNUAL, BIENNIAL, TRIENNIAL, CONTINUOUS
  riskLevel      String   @map("risk_level") // LOW, MEDIUM, HIGH, CRITICAL
  penalty        String?  @db.Text // Description of penalties
  applicableTo   String[] @default([]) @map("applicable_to") // Company sizes/sectors
  documentUrl    String?  @map("document_url")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  regulation Regulation  @relation(fields: [regulationId], references: [id])
  controls   Control[]
  deadlines  Deadline[]
  articleId  String?     @map("article_id")
  article    Article?    @relation(fields: [articleId], references: [id])

  @@map("obligations")
}

// ==================== CONTROL / CHECK / EVIDENCE ====================

model Control {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  obligationId  String   @map("obligation_id")
  titleFr       String   @map("title_fr")
  titleAr       String?  @map("title_ar")
  descriptionFr String?  @map("description_fr") @db.Text
  descriptionAr String?  @map("description_ar") @db.Text
  controlType   String   @map("control_type") // DOCUMENT, INSPECTION, TRAINING, CERTIFICATION
  expectedEvidence String?  @map("expected_evidence") // What proof is needed
  frequency     String   // How often this control should be performed
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  obligation Obligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)
  checks     Check[]
  evidence   Evidence[]

  @@map("controls")
}

model Check {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  controlId    String   @map("control_id")
  performedBy  String   @map("performed_by") // User ID
  checkDate    DateTime @map("check_date")
  status       String   // COMPLIANT, NON_COMPLIANT, PARTIAL, PENDING
  findings     String?  @db.Text // Inspection notes
  correctiveActions String? @map("corrective_actions") @db.Text
  nextCheckDue DateTime? @map("next_check_due")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  control   Control    @relation(fields: [controlId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [performedBy], references: [id])
  evidence  Evidence[]
  alerts    Alert[]

  actions   ActionItem[]
  
  auditId   String?  @map("audit_id")
  audit     Audit?   @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@map("checks")
}

model ActionItem {
  id          String   @id @default(uuid())
  checkId     String   @map("check_id")
  description String   @db.Text
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  dueDate     DateTime? @map("due_date")
  assignedTo  String?  @map("assigned_to") // User ID
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  check Check @relation(fields: [checkId], references: [id], onDelete: Cascade)

  @@map("action_items")
}

model Evidence {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  checkId     String?  @map("check_id")
  controlId   String?  @map("control_id")
  fileName    String   @map("file_name")
  filePath    String   @map("file_path") // Path in storage
  fileType    String   @map("file_type") // PDF, JPG, PNG, etc.
  fileSize    Int      @map("file_size") // Bytes
  uploadedAt  DateTime @default(now()) @map("uploaded_at")
  description String?  @db.Text
  metadata    Json?    @map("metadata") // Stores EXIF data (GPS, timestamp, device)
  isValid     Boolean  @default(true) @map("is_valid")

  // Relations
  check   Check?   @relation(fields: [checkId], references: [id], onDelete: Cascade)
  control Control? @relation(fields: [controlId], references: [id], onDelete: SetNull)

  @@map("evidence")
}

// ==================== DEADLINES & ALERTS ====================

model Deadline {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  obligationId  String   @map("obligation_id")
  dueDate       DateTime @map("due_date")
  status        String   @default("PENDING") // PENDING, COMPLETED, OVERDUE
  completedAt   DateTime? @map("completed_at")
  reminderSent  Boolean  @default(false) @map("reminder_sent")
  isRecurring   Boolean  @default(false) @map("is_recurring")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  obligation Obligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)

  @@map("deadlines")
}

model Alert {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  userId       String?  @map("user_id") // Recipient
  type         String   // DEADLINE_REMINDER, OVERDUE, NON_COMPLIANCE, AUDIT_SCHEDULED
  severity     String   // LOW, MEDIUM, HIGH, CRITICAL
  titleFr      String   @map("title_fr")
  titleAr      String?  @map("title_ar")
  messageFr    String   @map("message_fr") @db.Text
  messageAr    String?  @map("message_ar") @db.Text
  isRead       Boolean  @default(false) @map("is_read")
  isSent       Boolean  @default(false) @map("is_sent") // Email sent?
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  check   Check?  @relation(fields: [checkId], references: [id], onDelete: SetNull)
  checkId String? @map("check_id")

  @@map("alerts")
}

// ==================== AUDITS ====================

model AuditType {
  id            String   @id @default(uuid())
  name          String   @unique // e.g., "BSCI Full Audit", "Internal HSE Inspection"
  nameAr        String?  @map("name_ar")
  category      String   // SOCIAL, HSE, QUALITY, BRAND, SECURITY
  scope         String   @default("EXTERNAL") // EXTERNAL, INTERNAL
  frequency     Int?     // Frequency in months (optional default)
  description   String?  @db.Text
  descriptionAr String?  @map("description_ar") @db.Text
  checklistIds  String[] @default([]) // IDs of checklists/questionnaires (future)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  audits        Audit[]

  @@map("audit_types")
}

model Audit {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  auditTypeId   String   @map("audit_type_id")
  
  // Scheduling
  scheduledDate DateTime @map("scheduled_date")
  performedDate DateTime? @map("performed_date")
  
  // Auditor Info
  auditorName   String?  @map("auditor_name") // For external: "SGS", "Intertek"
  
  // Internal Audit Team
  leadAuditorId String? @map("lead_auditor_id") // Main internal auditor
  
  // Status & Results
  status        String   @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  score         Float?   // Numeric score (0-100) or rating (1-5)
  ratingLabel   String?  @map("rating_label") // "A", "Green", "Compliant"
  resultSummary String?  @map("result_summary") @db.Text
  
  // Artifacts
  reportUrl     String?  @map("report_url")
  
  // Follow-up
  nextAuditDue  DateTime? @map("next_audit_due")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  auditType   AuditType  @relation(fields: [auditTypeId], references: [id])
  leadAuditor User?      @relation("LeadAuditor", fields: [leadAuditorId], references: [id])
  auditTeam   User[]     @relation("AuditTeam")
  
  correctiveActions CorrectiveAction[]
  checks            Check[]

  @@map("audits")
}

model CorrectiveAction {
  id            String   @id @default(uuid())
  auditId       String   @map("audit_id")
  
  // Finding Details
  reference     String?  // e.g., "NC-2026-001"
  description   String   @db.Text
  severity      String   @default("MAJOR") // MINOR, MAJOR, CRITICAL
  
  // Action Plan
  actionPlan    String?  @map("action_plan") @db.Text
  assignedTo    String?  @map("assigned_to") // User ID
  dueDate       DateTime? @map("due_date")
  
  // Status
  status        String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, VERIFIED
  completedAt   DateTime? @map("completed_at")
  verifiedAt    DateTime? @map("verified_at")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  audit      Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  assignee   User?    @relation(fields: [assignedTo], references: [id])

  @@map("corrective_actions")
}

// ==================== REGULATORY WATCH ====================

model JortEntry {
  id           String   @id @default(uuid())
  titleFr      String   @map("title_fr")
  titleAr      String?  @map("title_ar")
  ministry     String?  // Ministry or Entity extracted (French)
  ministryAr   String?  @map("ministry_ar") // Ministry extracted (Arabic)
  type         String?  // Decree, Law, Order, etc.
  jortNumber   String?  @map("jort_number") // e.g. "018", "123"
  recordId     String   @unique @map("record_id") // PIST record ID for linking
  date         DateTime?
  pdfUrl       String?  @map("pdf_url") // French PDF
  pdfUrlAr     String?  @map("pdf_url_ar") // Arabic PDF
  status       String   @default("PENDING") // PENDING, RELEVANT, IGNORED
  processed    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("jort_entries")
}

model Article {
  id            String   @id @default(uuid())
  regulationId  String   @map("regulation_id")
  number        String   // Art 1, Art 2 bis, etc.
  contentFr     String?  @map("content_fr") @db.Text
  contentAr     String?  @map("content_ar") @db.Text
  
  // Relations
  regulation    Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  obligations   Obligation[]

  @@map("articles")
}
